// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Competition {
  id   Int      @id @default(autoincrement())
  name String
  date DateTime

  teams  Team[]
  rounds Round[]
}

model Team {
  id   Int    @id @default(autoincrement())
  name String

  competitionId Int
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  members TeamMember[]
}

model Competitor {
  id       Int                @id @default(autoincrement())
  name     String
  surname  String
  category CompetitorCategory @default(SENIOR)

  teams  TeamMember[]
  starts Start[]
}

model TeamMember {
  id Int @id @default(autoincrement())

  competitorId Int
  teamId       Int

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, competitorId])
}

model Round {
  id     Int    @id @default(autoincrement())
  name   String
  number Int

  competitionId Int
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  sectors Sector[]
  starts  Start[]

  createdAt DateTime @default(now())
}

model Sector {
  id   Int    @id @default(autoincrement())
  name String

  roundId Int
  round   Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  starts Start[]

  createdAt DateTime @default(now())
}

model Start {
  id Int @id @default(autoincrement())

  competitorId Int
  roundId      Int
  sectorId     Int

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  round      Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  sector     Sector     @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  position Int?
  weight   Int  @default(0)

  penaltyPoints Int    @default(0)
  sectorPoints  Float?

  subSector String?

  createdAt DateTime @default(now())

  @@unique([competitorId, roundId])
}

enum CompetitorCategory {
  SENIOR
  WOMAN
  U25
}

enum StartStatus {
  ACTIVE
  DNS // nie wystartował
  DNF // mie ukończył ???czy na pewno potrzebny???
  DSQ // dyskwalifikacja
}
